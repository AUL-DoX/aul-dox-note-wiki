---
import { getCollection } from 'astro:content';
import WikiLayout from '../layouts/WikiLayout.astro';
import noteLinks from '../../data/note-links.json';
import { getWikiPath, isPublicEntry } from '../content/wiki';

const entries = (await getCollection('wiki')).filter(isPublicEntry);
const linkedPages = new Map<string, { title: string; path: string; articleTitle: string }[]>();

for (const entry of entries) {
  for (const article of entry.data.noteArticles ?? []) {
    const pages = linkedPages.get(article.url) ?? [];
    pages.push({ title: entry.data.title, path: getWikiPath(entry), articleTitle: article.title });
    linkedPages.set(article.url, pages);
  }
}

const items = noteLinks.items.map((item) => ({
  ...item,
  source: item.source ?? 'rss',
  linkedPages: linkedPages.get(item.url) ?? [],
}));

const rssUrls = new Set(items.map((item) => item.url));
const manualItems = [...linkedPages.entries()]
  .filter(([url]) => !rssUrls.has(url))
  .map(([url, pages]) => ({
    title: pages[0]?.articleTitle ?? url,
    url,
    published: '',
    description: 'wikiページのnoteArticlesに採用済みのリンクです。',
    source: 'manual',
    linkedPages: pages,
  }));

const allItems = [...items, ...manualItems].sort((a, b) => {
  const aTime = a.published ? new Date(a.published).getTime() : 0;
  const bTime = b.published ? new Date(b.published).getTime() : 0;
  return bTime - aTime || a.title.localeCompare(b.title, 'ja');
});

const rssCount = items.filter((item) => item.source !== 'google').length;
const googleCount = items.filter((item) => item.source === 'google').length;
const linkedCount = items.filter((item) => item.linkedPages.length > 0).length;
const unlinkedCount = items.length - linkedCount;

function formatPublishedDate(value: string) {
  return new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: 'numeric',
    day: 'numeric',
    timeZone: 'Asia/Tokyo',
  }).format(new Date(value));
}
---

<WikiLayout wide title="note記事一覧 | AUL DoX note-wiki" description="note RSSとGoogle検索由来の記事URL一覧">
  <section class="page-header">
    <p class="eyebrow">Notes</p>
    <h1>note記事一覧</h1>
    <p>note RSSとGoogle検索から取得した記事URLの確認ページです。wikiページに採用済みの記事と、未整理の記事を確認できます。</p>
  </section>

  <section class="note-summary" aria-label="note記事の集計">
    <div>
      <span>{rssCount}</span>
      <p>RSS由来</p>
    </div>
    <div>
      <span>{googleCount}</span>
      <p>Google由来</p>
    </div>
    <div>
      <span>{unlinkedCount}</span>
      <p>未整理</p>
    </div>
    <div>
      <span>{manualItems.length}</span>
      <p>手動採用</p>
    </div>
    <div>
      <span>{linkedCount + manualItems.length}</span>
      <p>紐づけ済み</p>
    </div>
  </section>

  <div class="note-list">
    {
      allItems.map((item) => (
        <article class="note-item">
          <div class="note-item__meta">
            <span class:list={['status-pill', item.linkedPages.length > 0 ? 'status-pill--linked' : 'status-pill--unlinked']}>
              {item.linkedPages.length > 0 ? '紐づけ済み' : '未整理'}
            </span>
            <span>{item.source === 'google' ? 'Google由来' : item.source === 'manual' ? '手動採用' : 'RSS由来'}</span>
            {item.published && <span>{formatPublishedDate(item.published)}</span>}
          </div>
          <h2>
            <a href={item.url} target="_blank" rel="noopener noreferrer">
              {item.title}
            </a>
          </h2>
          {item.description && <p>{item.description}</p>}
          {item.linkedPages.length > 0 && (
            <div class="linked-pages">
              <span>掲載ページ</span>
              {item.linkedPages.map((page) => (
                <a href={page.path}>{page.title}</a>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</WikiLayout>
