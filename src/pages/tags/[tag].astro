---
import WikiLayout from '../../layouts/WikiLayout.astro';
import NoteArticleList from '../../components/NoteArticleList.astro';
import WikiSidebar from '../../components/WikiSidebar.astro';
import { getNoteIndexData, getNotePageItems, getNoteTags, getTotalNotePages } from '../../content/noteIndex';

export async function getStaticPaths() {
  const { sortedTags } = await getNoteIndexData();
  return sortedTags.map(([tag]) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const { allItems, categories, categoryCounts, sortedTags } = await getNoteIndexData();
const filteredItems = allItems.filter((item) => getNoteTags(item).includes(tag));
const currentPage = 1;
const totalPages = getTotalNotePages(filteredItems);
const pageItems = getNotePageItems(filteredItems, currentPage);
---

<WikiLayout wide title={`#${tag} | AUL DoX note-wiki`} description={`#${tag} に関連するnote記事一覧`}>
  <section class="wiki-home-header">
    <div>
      <p class="eyebrow">Tag</p>
      <h1>#{tag}</h1>
      <p>このタグに関連するnote記事を新しい順に表示しています。</p>
    </div>
  </section>

  <div class="wiki-shell">
    <WikiSidebar categories={categories} categoryCounts={categoryCounts} sortedTags={sortedTags} totalItems={allItems.length} />
    <NoteArticleList
      items={pageItems}
      currentPage={currentPage}
      totalPages={totalPages}
      totalItems={filteredItems.length}
      basePath={`/tags/${encodeURIComponent(tag)}/`}
    />
  </div>
</WikiLayout>
