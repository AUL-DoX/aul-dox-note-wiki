---
import WikiLayout from '../../../../layouts/WikiLayout.astro';
import NoteArticleList from '../../../../components/NoteArticleList.astro';
import WikiSidebar from '../../../../components/WikiSidebar.astro';
import { getCategoryBySlug } from '../../../../content/categories';
import { getNoteCategories, getNoteIndexData, getNotePageItems, getTotalNotePages } from '../../../../content/noteIndex';

export async function getStaticPaths() {
  const { allItems, categories } = await getNoteIndexData();
  const paths = [];

  for (const category of categories) {
    const filteredItems = allItems.filter((item) => getNoteCategories(item).includes(category.slug));
    const totalPages = getTotalNotePages(filteredItems);
    for (let page = 2; page <= totalPages; page += 1) {
      paths.push({ params: { category: category.slug, page: String(page) }, props: { page } });
    }
  }

  return paths;
}

const { category } = Astro.params;
const { page: currentPage } = Astro.props;
const { allItems, categories, categoryCounts, sortedTags } = await getNoteIndexData();
const categoryInfo = getCategoryBySlug(category);
const filteredItems = allItems.filter((item) => getNoteCategories(item).includes(category));
const totalPages = getTotalNotePages(filteredItems);
const pageItems = getNotePageItems(filteredItems, currentPage);
const title = categoryInfo?.title ?? category;
---

<WikiLayout wide title={`${title} ${currentPage}ページ目 | AUL DoX note-wiki`} description={`${title}に関連するnote記事一覧`}>
  <section class="wiki-home-header">
    <div>
      <p class="eyebrow">Category</p>
      <h1>{title}</h1>
      <p>note記事を10件ずつ表示しています。</p>
    </div>
  </section>

  <div class="wiki-shell">
    <WikiSidebar categories={categories} categoryCounts={categoryCounts} sortedTags={sortedTags} totalItems={allItems.length} />
    <NoteArticleList
      items={pageItems}
      currentPage={currentPage}
      totalPages={totalPages}
      totalItems={filteredItems.length}
      basePath={`/categories/${category}/`}
    />
  </div>
</WikiLayout>
