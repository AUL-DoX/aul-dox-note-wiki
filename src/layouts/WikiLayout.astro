---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoteLinkButton from '../components/NoteLinkButton.astro';
import '../styles/global.css';

const {
  title = 'AUL DoX note-wiki',
  description = '福祉DX、介護DX、就労継続支援、Obsidian活用、GASツール、AI制作メモを整理した公開wiki',
  noteUrl,
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class:list={['main', wide && 'main--wide']}>
      <slot />
      {noteUrl && <div class="note-action"><NoteLinkButton href={noteUrl} /></div>}
    </main>
    <Footer />
  </body>
</html>
